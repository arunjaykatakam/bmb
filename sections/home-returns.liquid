<section id="returns" class="section-shell">
  <div class="page-width">
    <div class="section-card" style="padding: 32px;">
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
      <div class="returns-grid">
        {% for block in section.blocks %}
          <article class="returns-card" {{ block.shopify_attributes }}>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.copy }}</p>
            <ul class="feature-list">
              {% if block.settings.feature_1 != blank %}<li>{{ block.settings.feature_1 }}</li>{% endif %}
              {% if block.settings.feature_2 != blank %}<li>{{ block.settings.feature_2 }}</li>{% endif %}
              {% if block.settings.feature_3 != blank %}<li>{{ block.settings.feature_3 }}</li>{% endif %}
            </ul>
          </article>
        {% endfor %}
      </div>
      <div class="note-banner"><strong>Top Tip:</strong> {{ section.settings.note }}</div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Returns",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Postage made simple"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Simple postage & returns"
    },
    {
      "type": "textarea",
      "id": "note",
      "label": "Note",
      "default": "Pack sets carefully in the original box when possible. Missing a few pieces? Don't worry - it happens. Check our FAQ for our friendly missing pieces policy."
    }
  ],
  "blocks": [
    {
      "type": "returns_option",
      "name": "Returns option",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "copy", "label": "Copy" },
        { "type": "text", "id": "feature_1", "label": "Feature 1" },
        { "type": "text", "id": "feature_2", "label": "Feature 2" },
        { "type": "text", "id": "feature_3", "label": "Feature 3" }
      ]
    }
  ],
  "max_blocks": 2,
  "presets": [
    {
      "name": "Returns",
      "blocks": [
        {
          "type": "returns_option",
          "settings": {
            "title": "Starter builder plan",
            "copy": "We've made it super simple. Your monthly set comes with a prepaid return label included. When you're ready to swap, just pack it up, stick on the label, and drop it at your nearest post office or collection point.",
            "feature_1": "Prepaid return label included",
            "feature_2": "Return postage fully covered",
            "feature_3": "One set per month cycle"
          }
        },
        {
          "type": "returns_option",
          "settings": {
            "title": "Unlimited & master plans",
            "copy": "With unlimited borrowing comes flexibility. You'll receive return labels via email that you can print at home. Simply purchase postage based on the set size - we'll provide weight estimates to make it easy.",
            "feature_1": "Email return labels provided",
            "feature_2": "You arrange return postage",
            "feature_3": "Swap as often as you like"
          }
        }
      ]
    }
  ]
}
{% endschema %}
