<section id="join" class="section-shell">
  <div class="page-width">
    <div class="cta-grid">
      <div class="cta-panel section-card">
        <div class="eyebrow">{{ section.settings.eyebrow }}</div>
        <h2 class="section-heading">{{ section.settings.heading }}</h2>
        <div class="section-copy">{{ section.settings.copy }}</div>
        <div class="button-row cta-panel__actions">
          <a class="button" href="{{ section.settings.primary_link | default: '#plans' }}">{{ section.settings.primary_label }}</a>
          <a class="button-secondary" href="{{ section.settings.secondary_link | default: 'mailto:hello@borrowmybricks.com' }}">{{ section.settings.secondary_label }}</a>
        </div>
      </div>
      <aside class="cta-panel section-card">
        <div class="meta-list">
          <div>
            <strong>{{ section.settings.meta_title_1 }}</strong>
            <div>{{ section.settings.meta_copy_1 }}</div>
          </div>
          <div>
            <strong>{{ section.settings.meta_title_2 }}</strong>
            <div>{{ section.settings.meta_copy_2 }}</div>
          </div>
          <div>
            <strong>{{ section.settings.meta_title_3 }}</strong>
            <div>{{ section.settings.meta_copy_3 }}</div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Ready to start?" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ready to Start Your LEGO Adventure?" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Join hundreds of families across the UK who are building, learning, and having brilliant fun with BorrowMyBricks. Whether you're a casual builder or a LEGO fanatic, we've got the perfect plan for you. Sign up today and get your first set delivered within 3-5 working days." },
    { "type": "text", "id": "primary_label", "label": "Primary button label", "default": "Join BorrowMyBricks today" },
    { "type": "url", "id": "primary_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "Contact Us" },
    { "type": "url", "id": "secondary_link", "label": "Secondary button link" },
    { "type": "text", "id": "meta_title_1", "label": "Meta title 1", "default": "Stay Connected" },
    { "type": "text", "id": "meta_copy_1", "label": "Meta copy 1", "default": "Email us at hello@borrowmybricks.com" },
    { "type": "text", "id": "meta_title_2", "label": "Meta title 2", "default": "Refer Friends" },
    { "type": "text", "id": "meta_copy_2", "label": "Meta copy 2", "default": "Get a free month when friends join!" },
    { "type": "text", "id": "meta_title_3", "label": "Meta title 3", "default": "Follow Us" },
    { "type": "text", "id": "meta_copy_3", "label": "Meta copy 3", "default": "Share your builds on social media" }
  ],
  "presets": [
    {
      "name": "CTA"
    }
  ]
}
{% endschema %}
