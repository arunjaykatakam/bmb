<section id="plans" class="section-shell">
  <div class="page-width">
    <div class="section-card" style="padding: 32px;">
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
      <div class="section-copy">{{ section.settings.copy }}</div>
      <div class="plans-grid" style="margin-top: 24px;">
        {% for block in section.blocks %}
          <article class="plan-card {% if block.settings.featured %}plan-card--featured{% endif %}" {{ block.shopify_attributes }}>
            <span class="plan-label">{{ block.settings.label }}</span>
            <h3>{{ block.settings.title }}</h3>
            <div class="plan-price">{{ block.settings.price }}</div>
            <p>{{ block.settings.copy }}</p>
            <ul class="feature-list">
              {% if block.settings.feature_1 != blank %}<li>{{ block.settings.feature_1 }}</li>{% endif %}
              {% if block.settings.feature_2 != blank %}<li>{{ block.settings.feature_2 }}</li>{% endif %}
              {% if block.settings.feature_3 != blank %}<li>{{ block.settings.feature_3 }}</li>{% endif %}
              {% if block.settings.feature_4 != blank %}<li>{{ block.settings.feature_4 }}</li>{% endif %}
            </ul>
            <div style="margin-top: 22px;">
              <a class="{% if block.settings.featured %}button{% else %}button-secondary{% endif %}" href="{{ block.settings.link | default: '#join' }}">{{ block.settings.button_label }}</a>
            </div>
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Plans",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Membership options"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Subscription plans for every builder"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "Whether you're just starting out or you're a LEGO fanatic, we've got the perfect plan for your family. All plans include access to our brilliant library, quality-checked sets, and dedicated customer support."
    }
  ],
  "blocks": [
    {
      "type": "plan",
      "name": "Plan",
      "settings": [
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "price", "label": "Price" },
        { "type": "textarea", "id": "copy", "label": "Copy" },
        { "type": "text", "id": "feature_1", "label": "Feature 1" },
        { "type": "text", "id": "feature_2", "label": "Feature 2" },
        { "type": "text", "id": "feature_3", "label": "Feature 3" },
        { "type": "text", "id": "feature_4", "label": "Feature 4" },
        { "type": "text", "id": "button_label", "label": "Button label" },
        { "type": "url", "id": "link", "label": "Button link" },
        { "type": "checkbox", "id": "featured", "label": "Featured plan", "default": false }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Plans",
      "blocks": [
        {
          "type": "plan",
          "settings": {
            "label": "Starter builder",
            "title": "Starter Builder",
            "price": "£10/month",
            "copy": "Perfect for curious beginners who want to dip their toes into the LEGO world.",
            "feature_1": "1 set per month",
            "feature_2": "Postage included both ways",
            "feature_3": "Access to Basic and Intermediate sets",
            "feature_4": "Ages 4-10 recommended",
            "button_label": "Join now"
          }
        },
        {
          "type": "plan",
          "settings": {
            "label": "Most popular",
            "title": "Unlimited Builder",
            "price": "£20/month",
            "copy": "For families who can't get enough LEGO! Swap sets as often as you like.",
            "feature_1": "Unlimited sets per month",
            "feature_2": "You cover return postage",
            "feature_3": "Access to all standard sets",
            "feature_4": "Ages 8-12 recommended",
            "button_label": "Most Popular",
            "featured": true
          }
        },
        {
          "type": "plan",
          "settings": {
            "label": "Premium",
            "title": "Master Builder",
            "price": "£50/month",
            "copy": "The ultimate experience for serious LEGO enthusiasts and advanced builders.",
            "feature_1": "Unlimited premium sets per month",
            "feature_2": "You cover return postage",
            "feature_3": "Exclusive Technic & advanced sets",
            "feature_4": "Ages 8-12 recommended",
            "button_label": "Go Premium"
          }
        }
      ]
    }
  ]
}
{% endschema %}
